{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Server=localhost;Port=3306;Database=school_events;User Id=app;Password=app_local_pw;AllowPublicKeyRetrieval=True;SslMode=None;"
  },
  "Worker": {
    "PollIntervalSeconds": 3,
    "BatchSize": 20,
    "BaseRetryDelaySeconds": 10,
    "StaleProcessingSeconds": 300
  },
  "Smtp": {
    "Enabled": false,
    "Host": "",
    "Port": 587,
    "User": "",
    "Password": "",
    "From": "School Events <no-reply@localhost>",
    "UseStartTls": true
  }
}
